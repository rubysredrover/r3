# Ruby's Red Rover v2 — agent layer environment
# Copy to .env and fill in values

# Claude Agent SDK orchestrator
ANTHROPIC_API_KEY=

# Gemini 2.5 Flash for CP-aware voice transcription
GOOGLE_API_KEY=

# Bolo MCP / REST API for grant checks
BOLO_API_KEY=

# Bolo API base URL (calendar project API)
BOLO_API_URL=http://localhost:3000

# Vapi outbound voice call
VAPI_API_KEY=

# Vapi phone number ID used as caller ID
VAPI_PHONE_NUMBER_ID=

# "Folino's" number for the demo (= your phone)
VAPI_TARGET_PHONE=

# ElevenLabs TTS + voice cloning
ELEVENLABS_API_KEY=

# Voice IDs below seed the Bolo grants — they are NOT pulled directly by the
# tools. The agent resolves voice IDs via `bolo.get_grants(...)`, which returns
# the ID inside the grant scopes payload. Revoking the grant revokes the voice.
# These env vars only seed the mock grants in dev. In prod the grants live in
# the Bolo API and these env vars are unused.

# Seeds @ruby → @mars widget=voice scope=demo_input
# (Ruby's consent for the agent to use her cloned voice for live demo input.)
RUBY_VOICE_ID=

# Seeds @chantal → @ruby widget=voice scope=outbound_calls
# (Chantal — radio DJ — donated her voice for Ruby's outbound calls.)
CHANTAL_VOICE_ID=vAfuZdldSpxthmIQYOBC
